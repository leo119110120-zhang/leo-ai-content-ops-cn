<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title }}｜审核中心</title>
  <style>
    :root{--blue:#2457E6;--paper:#F6F2E9;--orange:#FF8A34;--ink:#20242C}
    *{box-sizing:border-box}body{margin:0;background:var(--paper);color:var(--ink);font:16px/1.7 system-ui,"Microsoft YaHei",sans-serif}
    header{padding:28px 5vw;background:var(--ink);color:white}main{max-width:1400px;margin:auto;padding:28px 5vw}
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.card{background:white;border-radius:18px;padding:24px;box-shadow:0 8px 30px #20242c12;margin-bottom:24px}
    button{border:0;border-radius:10px;padding:12px 18px;cursor:pointer}.primary{background:var(--blue);color:white}.warn{background:var(--orange)}
    .images{display:flex;gap:12px;overflow:auto}.images img{width:220px;border-radius:12px}.actions{position:sticky;bottom:0;background:#fffffff2;padding:16px;border-radius:16px}
    textarea{width:100%;min-height:90px}.copy-source{white-space:pre-wrap;background:#f5f5f5;padding:12px;border-radius:10px}@media(max-width:900px){.grid{grid-template-columns:1fr}}
  </style>
</head>
<body data-content-id="{{ content_id }}">
  <header><small>{{ status }}</small><h1>{{ title }}</h1><p>{{ reader_payoff }}</p></header>
  <main>
    <section class="grid">
      <div class="card"><h2>为什么有人愿意看</h2><p>选题总分：<strong>{{ score.total }}</strong>；需求与当下性：<strong>{{ score.demand_timeliness }}</strong></p><ul>{% for value in demand_evidence %}<li>{{ value }}</li>{% endfor %}</ul><p><strong>对标差异：</strong>{{ differentiation }}</p></div>
      <div class="card"><h2>标题候选</h2><ol>{% for value in titles %}<li>{{ value }}</li>{% endfor %}</ol><h3>首图候选</h3><ol>{% for value in covers %}<li>{{ value }}</li>{% endfor %}</ol></div>
    </section>
    <section class="grid">
      <article class="card"><h2>公众号</h2><button onclick="copyText('wechat')">一键复制</button><div>{{ wechat_html|safe }}</div><details><summary>查看Markdown</summary><pre id="wechat" class="copy-source">{{ wechat_raw }}</pre></details></article>
      <article class="card"><h2>小红书</h2><button onclick="copyText('xhs')">一键复制</button><div>{{ xhs_html|safe }}</div><details><summary>查看Markdown</summary><pre id="xhs" class="copy-source">{{ xhs_raw }}</pre></details></article>
    </section>
    <section class="card"><h2>图片</h2><p><a href="images.zip" download>下载全部图片</a></p><div class="images">{% for name in images %}<a href="images/{{ name }}" download><img src="images/{{ name }}" alt="{{ name }}"></a>{% endfor %}</div></section>
    <section class="card"><h2>来源</h2><ul>{% for source in sources %}<li>{{ source.kind }}：{{ source.path or source.url }}</li>{% endfor %}</ul><h2>质检</h2>{{ quality_html|safe }}</section>
    <section class="actions"><textarea id="note" placeholder="填写修改或放弃理由"></textarea><button class="primary" data-action="approve" onclick="act('approve')">通过</button> <button class="warn" data-action="revise" onclick="act('revise')">退回修改</button> <button data-action="reject" onclick="act('reject')">放弃</button></section>
  </main>
  <script>
    window.addEventListener('DOMContentLoaded',()=>fetch('/api/review-start',{method:'POST'}));
    async function copyText(id){await navigator.clipboard.writeText(document.getElementById(id).innerText)}
    async function act(action){const response=await fetch('/api/action',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action,note:document.getElementById('note').value})});const data=await response.json();alert(data.message);if(response.ok)location.reload()}
  </script>
</body>
</html>
